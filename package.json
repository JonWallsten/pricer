{
  "name": "pricer",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:api": "php -S localhost:8080 api/router.php",
    "build": "ng build --base-href /pricer/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "node scripts/deploy.mjs",
    "deploy:frontend": "node scripts/deploy.mjs --frontend-only",
    "deploy:api": "node scripts/deploy.mjs --api-only",
    "deploy:credentials": "node scripts/deploy.mjs --credentials-only",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:status": "node scripts/db-migrate.mjs --status",
    "test:scripts": "vitest run --config scripts/vitest.config.mjs",
    "test:api": "vitest run --config scripts/vitest.api.config.mjs",
    "lint": "eslint 'src/**/*.{ts,html}'",
    "lint:fix": "eslint 'src/**/*.{ts,html}' --fix",
    "format": "prettier --write 'src/**/*.{ts,html,scss,css,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,html,scss,css,json}'"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^21.3.0",
    "basic-ftp": "^5.2.0",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "mysql2": "^3.19.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  }
}
