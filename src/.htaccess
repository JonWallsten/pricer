# ─── Block access to hidden (dot) files ───────────────────
# Prevents .credentials.env and any other dotfiles from being served
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Prevent LiteSpeed from caching index.html
<IfModule LiteSpeed>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Also set standard headers for non-LiteSpeed scenarios
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Let everything else (hashed JS/CSS) cache long
<FilesMatch "\.(js|css|ico|png|jpg|jpeg|svg|woff2?)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
