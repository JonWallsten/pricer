# Database
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT signing key (random string, e.g. openssl rand -hex 32)
JWT_SECRET=

# Admin account
# Set this to the Google "sub" claim / users.google_id value for the admin account.
ADMIN_GOOGLE_ID=

# Optional contact/reference email for the admin user
ADMIN_EMAIL=

# Cross-store product discovery (optional)
SERPAPI_API_KEY=
SERPAPI_SEARCH_COUNTRY=se
SERPAPI_SEARCH_LOCALE=sv-SE

# App deployment (no trailing slash)
# APP_URL: full public URL to the frontend, e.g. https://example.com/pricer
# APP_API_BASE_PATH: URL path prefix for the API, e.g. /pricer/api
APP_URL=
APP_API_BASE_PATH=/pricer/api
